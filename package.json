  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "session",
    "context",
    "reduce"
  ],
  "homepage": "https://github.com/toorusr/pi-reduce#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toorusr/pi-reduce.git"
  },
  "bugs": {
    "url": "https://github.com/toorusr/pi-reduce/issues"
  },
  "files": [
    "extensions",
    "README.md",
    "LICENSE",
