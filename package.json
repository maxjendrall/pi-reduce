    "tsconfig.json"
  ],
  "scripts": {
    "check": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run check"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "^0.74.0",
    "@earendil-works/pi-ai": "^0.74.0",
